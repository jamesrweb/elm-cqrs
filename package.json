  "dependencies": {
    "elm": "0.19.1-6",
    "elm-coverage": "^0.4.1",
    "elm-doc-preview": "^6.0.1",
    "elm-format": "^0.8.8",
    "elm-json": "^0.2.13",
    "elm-review": "^2.13.5",
    "elm-test": "0.19.1-revision15"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8"
  }
